# Byte-compiled / cache
__pycache__/
*.py[cod]
*.egg-info/
.pytest_cache/
.mypy_cache/

# Environments
.venv/
venv/
env/

# Data (raw SCADA CSV is not redistributed - see Data/README.md)
Data/raw/*
!Data/raw/.gitkeep
Data/processed/*
!Data/processed/.gitkeep

# Outputs
checkpoints/*
!checkpoints/.gitkeep
figures/*.png
figures/*.pdf
!figures/.gitkeep
results/*.csv
results/*.json
results/*.png
!results/.gitkeep
logs/
runs/

# OS / IDE
.DS_Store
.idea/
.vscode/
*.swp

# Jupyter
.ipynb_checkpoints/
